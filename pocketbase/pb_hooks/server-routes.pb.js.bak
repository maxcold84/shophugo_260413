$app.onServe().bindFunc(function(e) {
    function esc(value) {
        var input = value === null || value === undefined ? "" : String(value);
        return input
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;")
            .replace(/'/g, "&#39;");
    }

    function loadSession(sessionId) {
        var records;
        if (!sessionId) {
            return null;
        }
        records = e.app.findRecordsByFilter(
            "cms_sessions",
            "session_id = {:sid} && expires_at > {:now} && revoked_at = ''",
            "-created",
            1,
            0,
            { sid: sessionId, now: new Date().toISOString() }
        );
        return records && records.length ? records[0] : null;
    }

    function shell(title, active, csrfToken, body) {
        function link(label, href, isActive) {
            return "<a class=\"" + (isActive ? "active" : "") + "\" href=\"" + href + "\">" + label + "</a>";
        }

        return [
            "<!doctype html><html lang=\"en\"><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">",
            "<title>" + esc(title) + "</title>",
            "<style>body{font-family:Arial,sans-serif;background:#f6f7fb;color:#1f2937;margin:0;}a{color:#1d4ed8;text-decoration:none;}a:hover{text-decoration:underline;}.shell{display:grid;grid-template-columns:240px 1fr;min-height:100vh;}.nav{background:#111827;color:#fff;padding:24px;}.nav a{display:block;color:#cbd5e1;padding:8px 0;}.nav a.active{color:#fff;font-weight:700;}.content{padding:32px;}.panel{background:#fff;border:1px solid #e5e7eb;border-radius:16px;padding:24px;box-shadow:0 10px 30px rgba(15,23,42,.05);}.grid{display:grid;gap:16px;}.grid.two{grid-template-columns:repeat(2,minmax(0,1fr));}.meta{color:#6b7280;font-size:14px;}button,.button{display:inline-block;background:#111827;color:#fff;border:none;border-radius:10px;padding:10px 16px;cursor:pointer;}.button.secondary{background:#e5e7eb;color:#111827;}@media (max-width:900px){.shell{grid-template-columns:1fr;}.nav{display:flex;gap:16px;overflow:auto;}.grid.two{grid-template-columns:1fr;}}</style>",
            "</head><body><div class=\"shell\"><nav class=\"nav\"><h1 style=\"margin-top:0;font-size:20px;\">CMS</h1>",
            link("Dashboard", "/cms/dashboard", active === "dashboard"),
            link("Builds", "/cms/builds", active === "builds"),
            "<form method=\"POST\" action=\"/cms/logout\" style=\"margin-top:16px;\"><input type=\"hidden\" name=\"_csrf\" value=\"" + esc(csrfToken || "") + "\"><button type=\"submit\" class=\"button secondary\">Logout</button></form>",
            "</nav><main class=\"content\">" + body + "</main></div></body></html>"
        ].join("");
    }

    function buildPanel() {
        var states = e.app.findRecordsByFilter("build_state", "id != ''", "created asc", 1, 0);
        var logs = e.app.findRecordsByFilter("build_logs", "id != ''", "-created", 10, 0);
        var state = states && states.length ? states[0] : null;
        var i;
        var logHtml = "";

        for (i = 0; i < logs.length; i += 1) {
            logHtml += [
                "<div style=\"border:1px solid #e5e7eb;border-radius:12px;padding:12px;margin-bottom:12px;\">",
                "<p style=\"margin:0 0 6px;\"><strong>" + esc(logs[i].getString("status")) + "</strong> via " + esc(logs[i].getString("triggered_by")) + "</p>",
                "<p class=\"meta\" style=\"margin:0 0 6px;\">" + esc(String(logs[i].created || "")) + (logs[i].getInt("duration_ms") ? (" · " + logs[i].getInt("duration_ms") + "ms") : "") + "</p>",
                "<pre style=\"white-space:pre-wrap;background:#f8fafc;padding:12px;border-radius:10px;margin:0;\">" + esc(logs[i].getString("output")) + "</pre>",
                "</div>"
            ].join("");
        }

        if (!state) {
            return "<div class=\"panel\"><p class=\"meta\">No build state row exists yet.</p></div>";
        }

        return [
            "<div class=\"panel\"><div class=\"grid two\"><div>",
            "<h2 style=\"margin-top:0;\">Current state</h2>",
            "<p>Queue dirty: <strong>" + state.getBool("queue_dirty") + "</strong></p>",
            "<p>Build running: <strong>" + state.getBool("build_running") + "</strong></p>",
            "<p>Rerun requested: <strong>" + state.getBool("rerun_requested") + "</strong></p>",
            "<p>Last changed: <span class=\"meta\">" + esc(state.getString("last_changed_at")) + "</span></p>",
            "<p>Last built: <span class=\"meta\">" + esc(state.getString("last_built_at")) + "</span></p>",
            "<p>Build started: <span class=\"meta\">" + esc(state.getString("build_started_at")) + "</span></p>",
            "</div><div><h2 style=\"margin-top:0;\">Recent logs</h2>",
            (logHtml || "<p class=\"meta\">No build logs yet.</p>"),
            "</div></div></div>"
        ].join("");
    }

    e.router.get("/cms/login", function(c) {
        return c.html(200, [
            "<!doctype html><html lang=\"en\"><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"><title>CMS Login</title>",
            "<style>body{font-family:Arial,sans-serif;background:#0f172a;color:#e2e8f0;display:grid;place-items:center;min-height:100vh;margin:0;}.card{width:min(420px,92vw);background:#fff;color:#0f172a;border-radius:24px;padding:32px;box-shadow:0 20px 60px rgba(15,23,42,.35);}h1{margin-top:0;margin-bottom:8px;font-size:28px;}p{color:#475569;}label{display:block;font-size:14px;font-weight:600;margin-bottom:8px;}input{width:100%;padding:12px;border:1px solid #cbd5e1;border-radius:12px;box-sizing:border-box;margin-bottom:16px;}button{width:100%;padding:12px;border:none;border-radius:12px;background:#0f172a;color:#fff;font-weight:700;cursor:pointer;}</style>",
            "</head><body><section class=\"card\"><h1>CMS Login</h1><p>Use a PocketBase superuser account to access the privileged CMS routes.</p>",
            "<form method=\"POST\" action=\"/cms/login\"><label>Email <input type=\"email\" name=\"email\"></label><label>Password <input type=\"password\" name=\"password\"></label><button type=\"submit\">Sign in</button></form>",
            "</section></body></html>"
        ].join(""));
    });
    $app.logger().info("registered /cms/login");

    e.router.get("/cms", function(c) {
        return c.redirect(302, "/cms/dashboard");
    });
    $app.logger().info("registered /cms");

    e.router.get("/cms/dashboard", function(c) {
        var cookie = c.request().cookie("cms_session");
        var sessionId = cookie ? cookie.value() : "";
        var session = loadSession(sessionId);
        var states;
        var state;
        var productsCount;
        var categoriesCount;
        var ordersCount;
        var body;

        if (!session) {
            return c.redirect(302, "/cms/login");
        }

        states = e.app.findRecordsByFilter("build_state", "id != ''", "created asc", 1, 0);
        state = states && states.length ? states[0] : null;
        productsCount = e.app.findRecordsByFilter("products", "id != ''", "", 500, 0).length;
        categoriesCount = e.app.findRecordsByFilter("categories", "id != ''", "", 500, 0).length;
        ordersCount = e.app.findRecordsByFilter("orders", "id != ''", "", 500, 0).length;

        body = [
            "<div class=\"panel\"><h1 style=\"margin-top:0;\">Dashboard</h1>",
            "<p class=\"meta\">PocketBase owns privileged actions and build orchestration. Hugo owns public storefront rendering.</p>",
            "<div class=\"grid two\" style=\"margin-top:24px;\">",
            "<div class=\"panel\"><h2 style=\"margin-top:0;\">Catalog</h2>",
            "<p><strong>" + productsCount + "</strong> products</p>",
            "<p><strong>" + categoriesCount + "</strong> categories</p>",
            "<p><strong>" + ordersCount + "</strong> orders</p></div>",
            "<div class=\"panel\"><h2 style=\"margin-top:0;\">Build Queue</h2>",
            "<p>Queue dirty: <strong>" + (state ? state.getBool("queue_dirty") : false) + "</strong></p>",
            "<p>Build running: <strong>" + (state ? state.getBool("build_running") : false) + "</strong></p>",
            "<p>Rerun requested: <strong>" + (state ? state.getBool("rerun_requested") : false) + "</strong></p>",
            "<p>Last changed: <span class=\"meta\">" + esc(state ? state.getString("last_changed_at") : "") + "</span></p>",
            "<p>Last built: <span class=\"meta\">" + esc(state ? state.getString("last_built_at") : "") + "</span></p></div>",
            "</div></div>"
        ].join("");

        return c.html(200, shell("CMS Dashboard", "dashboard", session.getString("csrf_token"), body));
    });
    $app.logger().info("registered /cms/dashboard");

    e.router.get("/cms/builds", function(c) {
        var cookie = c.request().cookie("cms_session");
        var sessionId = cookie ? cookie.value() : "";
        var session = loadSession(sessionId);

        if (!session) {
            return c.redirect(302, "/cms/login");
        }

        return c.html(200, shell("Build Status", "builds", session.getString("csrf_token"), [
            "<div class=\"panel\"><h1 style=\"margin-top:0;\">Build Status</h1>",
            "<p class=\"meta\">The CMS reads persisted build state and recent logs.</p>",
            buildPanel(),
            "</div>"
        ].join("")));
    });
    $app.logger().info("registered /cms/builds");

    e.router.get("/cms/fragments/build-status", function(c) {
        var cookie = c.request().cookie("cms_session");
        var sessionId = cookie ? cookie.value() : "";
        var session = loadSession(sessionId);
        if (!session) {
            return c.html(401, "<div class=\"flash error\">You need to sign in to continue.</div>");
        }
        return c.html(200, buildPanel());
    });
    $app.logger().info("registered /cms/fragments/build-status");

    e.router.get("/fragments/cart/checkout-summary", function(c) {
        return c.html(200, [
            "<div class=\"rounded-3xl border border-slate-200 bg-white p-6 shadow-sm\">",
            "<h2 style=\"margin-top:0;\">Checkout summary</h2>",
            "<p class=\"text-sm text-slate-500\">No checkout lines are available.</p>",
            "</div>"
        ].join(""));
    });
    $app.logger().info("registered /fragments/cart/checkout-summary");

    e.next();
});
